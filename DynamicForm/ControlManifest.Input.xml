<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <!--
    control-type="standard"
    ─────────────────────────────────────────────────────────────────────
    Standard controls use ComponentFramework.StandardControl<IInputs,IOutputs>.
    React is bundled inside the PCF package (no <platform-library> needed).
    CSS is injected by the framework via the <css> resource declaration below.
    This type avoids the virtual-control restrictions that can cause canvas-app
    focus / SetFocus() issues on mobile.
  -->
  <control namespace="DynamicForm"
           constructor="DynamicForm"
           version="1.3.4"
           display-name-key="DynamicForm"
           description-key="JSON-driven dynamic form with native React keyboard focus management (v1.3.4)"
           control-type="standard">

    <external-service-usage enabled="false" />

    <!-- ══════════════════════════════════════════════════════════════════
         INPUT PROPERTIES  –  data flowing INTO the PCF from Power Apps
    ══════════════════════════════════════════════════════════════════════

      FormDataJSON  (bound)
        · Power Apps sets this to a JSON array of FormRecord objects.
        · "bound" allows bidirectional registration in Canvas App formulas
          (e.g.  DynamicForm1.FormDataJSON  or  Set(varFormData, ...)).
        · The PCF reads it in updateView; only the output properties below
          communicate changes back to Power Apps.
    -->
    <property name="FormDataJSON"
              display-name-key="Form Data JSON"
              description-key="JSON array of FormRecord objects. Will be sorted by OrderNo inside the PCF."
              of-type="Multiple"
              usage="bound"
              required="true" />

    <!--
      RefValoresCategoricosJSON  (input)
        · Master list of categorical dropdown options.
        · input-only: Power Apps provides the list; the PCF never writes back.
        · Shape: [{ FK_Variable, PK_ValorCategorico, Valor }]
    -->
    <property name="RefValoresCategoricosJSON"
              display-name-key="Ref Categoric Values JSON"
              description-key="JSON array of {FK_Variable, PK_ValorCategorico, Valor} used to populate Categorica dropdowns"
              of-type="Multiple"
              usage="input"
              required="false" />

    <!--
      skipNonTextField  (input)
        · Boolean toggle to control keyboard navigation behavior.
        · false (default): Tab/Enter moves to the immediate next field (text, dropdown, photo).
        · true: Tab/Enter skips over Categorica and Foto fields, moving only to Texto/Numero fields.
    -->
    <property name="skipNonTextField"
              display-name-key="Skip Non-Text Fields"
              description-key="When true, Enter key skips Categorica and Foto fields, jumping only to Texto/Numero entero/Numero decimal fields"
              of-type="TwoOptions"
              usage="input"
              required="false" />

    <!-- ══════════════════════════════════════════════════════════════════
         OUTPUT PROPERTIES  –  data flowing OUT of the PCF to Power Apps
         Power Apps reads these after notifyOutputChanged() is called.
    ══════════════════════════════════════════════════════════════════════

      OutAction  – the action token Power Apps should react to.
        Possible values:
          "SAVE_RECORD"               – persist the row, stay on same Plantacion
          "SAVE_AND_NEXT_PLANTACION"  – persist the last row, advance to next record
          "TAKE_PHOTO"                – open the camera; read OutActiveVariable for the FK
    -->
    <property name="OutAction"
              display-name-key="Output Action"
              description-key="SAVE_RECORD | SAVE_AND_NEXT_PLANTACION | TAKE_PHOTO"
              of-type="SingleLine.Text"
              usage="bound"
              required="false" />

    <!--
      OutModifiedRecord – the single FormRecord the user just edited,
      serialized as a JSON string so Power Apps can Patch() it to Dataverse.
    -->
    <property name="OutModifiedRecord"
              display-name-key="Output Modified Record"
              description-key="JSON string of the single FormRecord that was saved"
              of-type="Multiple"
              usage="bound"
              required="false" />

    <!--
      OutActiveVariable – FK_Variable of the row that triggered TAKE_PHOTO.
      Power Apps uses this to associate the captured image with the correct row.
    -->
    <property name="OutActiveVariable"
              display-name-key="Output Active Variable"
              description-key="FK_Variable of the row that triggered TAKE_PHOTO"
              of-type="Whole.None"
              usage="output" />

    <!--
      OutEventTick – monotonically increasing event token.
      This changes on every notifyOutputChanged call and helps Canvas
      reliably detect OnChange even when action and record are identical.
    -->
    <property name="OutEventTick"
              display-name-key="Output Event Tick"
              description-key="Incremental token updated for every output event"
              of-type="Whole.None"
              usage="bound"
              required="false" />

    <!-- ════════════
         RESOURCES
    ════════════════ -->
    <resources>
      <!-- Entry point: pcf-scripts bundles this with React + ReactDOM -->
      <code path="index.ts" order="1" />
      <!-- CSS is injected by the PCF runtime; do NOT @import it in TypeScript -->
      <css path="css/DynamicForm.css" order="1" />
    </resources>

  </control>
</manifest>
